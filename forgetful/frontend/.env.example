# Copy this file to `.env.local` inside `frontend/` before running.

# Backend API
VITE_API_BASE_URL="http://localhost:8000"

# WebSocket stream
VITE_WEBSOCKET_URL="ws://localhost:8000/ws"

# How often the frontend sends frames to the backend (lower = faster, more load)
VITE_FRAME_INTERVAL_MS=100

# Webcam / stream sizing (optional; defaults are fine)
VITE_CAMERA_WIDTH=1920
VITE_CAMERA_HEIGHT=1080
VITE_CAMERA_FPS=30
VITE_CAMERA_ASPECT_RATIO=1.7777778

# Not required for the current backend-driven features,
# but included for compatibility with earlier setups.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_OPTIONAL_ANON_KEY"

VITE_ENABLE_AUDIO_PLAYBACK=false

