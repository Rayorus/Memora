# Copy this file to `.env.local` before running.
# Never commit real secrets (Supabase keys, LLM keys) to GitHub.

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
# Optional (currently the backend uses the Service Role key).
SUPABASE_ANON_KEY="YOUR_OPTIONAL_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"
SUPABASE_STORAGE_BUCKET="face-images"

# ── LLM ───────────────────────────────────────────────────────
# One of: anthropic | openai | groq
LLM_PROVIDER="groq"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GROQ_API_KEY="YOUR_GROQ_KEY"
GROK_API_KEY=""
LLM_MODEL="llama-3.1-8b-instant"

# ── Whisper / STT ──────────────────────────────────────────────
WHISPER_MODE="groq-api"
WHISPER_MODEL_SIZE="base"
GROQ_TRANSCRIBE_MODEL="whisper-large-v3-turbo"

# ── Face recognition ───────────────────────────────────────────
FACE_BACKEND="deepface"
FACE_MODEL="Facenet512"
FACE_SIMILARITY_THRESHOLD=0.45
FACE_MATCH_MIN_MARGIN=0.05
FACE_DISTANCE_THRESHOLD=0.55
FACE_DETECTOR_BACKEND="yunet"
FACE_MIN_SIZE=30
FACE_DETECTION_CONFIDENCE=0.5
FACE_NMS_IOU=0.5
FACE_CONSENSUS_WINDOW=2
FACE_CONSENSUS_HITS=2
FACE_RECOGNITION_INTERVAL=3
FACE_MAX_FACES_PER_FRAME=3
FACE_DETECT_RESIZE_WIDTH=640
FACE_DETECT_RESIZE_HEIGHT=480

# ── Backend ────────────────────────────────────────────────────
BACKEND_HOST="0.0.0.0"
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS="http://localhost:3000"
SECRET_KEY="change-me"

# ── Demo only ──────────────────────────────────────────────────
# Enables the in-app “Restart” button to wipe Supabase tables.
ALLOW_FULL_DATABASE_RESET=false

